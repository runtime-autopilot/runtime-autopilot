FROM python:3.12-slim
WORKDIR /app
COPY . /adapters/django
COPY runtime-autopilot /usr/local/bin/runtime-autopilot
RUN chmod +x /usr/local/bin/runtime-autopilot
RUN pip install --no-cache-dir --upgrade pip setuptools wheel
RUN pip install --no-cache-dir "/adapters/django[dev]"
ENV RUNTIME_AUTOPILOT_BIN=runtime-autopilot
ENV DJANGO_SETTINGS_MODULE=tests.settings
ENV PYTHONPATH=/adapters/django
CMD ["python", "-m", "pytest", "/adapters/django/tests", "-v"]
    